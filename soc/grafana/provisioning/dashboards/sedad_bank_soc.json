{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "RSS BANK — SOC Security Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🔐 RSS BANK — SOC Dashboard",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Requêtes totales (1h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-access\"}[1h]))",
          "legendFormat": "Requêtes",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Échecs connexion (1h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-security\"} |= \"LOGIN_FAILED\" [1h]))",
          "legendFormat": "Échecs",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Injections SQL (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-security\"} |= \"SQL_INJECTION\" [24h]))",
          "legendFormat": "SQL Injection",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Brute Force (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-security\"} |= \"BRUTE_FORCE\" [24h]))",
          "legendFormat": "Brute Force",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "📈 Activité en temps réel",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "LOGIN_FAILED" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "BRUTE_FORCE" },   "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "SQL_INJECTION" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "XSS" },           "properties": [{ "id": "color", "value": { "fixedColor": "pink",   "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "LOGIN_SUCCESS" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 7,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Événements de sécurité",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-security\"} |= \"LOGIN_FAILED\" [$__interval]))",
          "legendFormat": "LOGIN_FAILED",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-security\"} |= \"BRUTE_FORCE\" [$__interval]))",
          "legendFormat": "BRUTE_FORCE",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-security\"} |= \"SQL_INJECTION\" [$__interval]))",
          "legendFormat": "SQL_INJECTION",
          "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-security\"} |= \"XSS\" [$__interval]))",
          "legendFormat": "XSS",
          "refId": "D"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-security\"} |= \"LOGIN_SUCCESS\" [$__interval]))",
          "legendFormat": "LOGIN_SUCCESS",
          "refId": "E"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ip" },    "properties": [{ "id": "displayName", "value": "IP Source" }, { "id": "custom.width", "value": 130 }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Tentatives" }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "red", "value": 10 }] } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 8,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Tentatives" }] },
      "title": "Top IPs attaquantes (1h)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "topk(10, sum by (ip) (count_over_time({job=\"django-security\"} |= \"LOGIN_FAILED\" | json | __error__=`` [1h])))",
          "legendFormat": "{{ip}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 9,
      "title": "📋 Logs en direct",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 15 },
      "id": 10,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "wrapLogMessage": true
      },
      "title": "🚨 Événements sécurité (live)",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "{job=\"django-security\"}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 15 },
      "id": 11,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "wrapLogMessage": true
      },
      "title": "🌐 Access Log (live)",
      "type": "logs",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "{job=\"django-access\"}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 12,
      "title": "📊 Codes HTTP",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki-main" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "200" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "201" }, "properties": [{ "id": "color", "value": { "fixedColor": "teal",   "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "400" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "401" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "403" }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "500" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 13,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "Codes de réponse HTTP",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-access\"} |= \"\\\"status\\\": 200\" [$__interval]))",
          "legendFormat": "200 OK", "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-access\"} |= \"\\\"status\\\": 400\" [$__interval]))",
          "legendFormat": "400 Bad Request", "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-access\"} |= \"\\\"status\\\": 401\" [$__interval]))",
          "legendFormat": "401 Unauthorized", "refId": "C"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-access\"} |= \"\\\"status\\\": 403\" [$__interval]))",
          "legendFormat": "403 Forbidden", "refId": "D"
        },
        {
          "datasource": { "type": "loki", "uid": "loki-main" },
          "expr": "sum(count_over_time({job=\"django-access\"} |= \"\\\"status\\\": 500\" [$__interval]))",
          "legendFormat": "500 Server Error", "refId": "E"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["soc", "security", "fintech"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RSS BANK — SOC",
  "uid": "rss-bank-soc",
  "version": 1
}
